<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ActivityWatcher" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/sample_primary</item>
        <item name="colorPrimaryDark">@color/sample_primary_dark</item>
        <item name="colorAccent">@color/sample_accent</item>
        <item name="android:windowBackground">@drawable/bg_sample_screen</item>
        <item name="alertDialogTheme">@style/SampleAlertDialog</item>
    </style>

    <style name="SampleAlertDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">@color/sample_primary</item>
        <item name="android:textColorPrimary">@color/sample_text_primary</item>
        <item name="android:textColorSecondary">@color/sample_text_secondary</item>
    </style>
</resources>
